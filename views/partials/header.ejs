<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= titulo || "Superhéroes App" %></title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Estilos propios -->
  <style>
    body {
      background-color: #0f172a;
      color: #e2e8f0;
    }
    .navbar {
      background: linear-gradient(90deg, #1e3a8a, #2563eb);
    }
  </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark shadow">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/heroes"><h1 class="text-center">🦸 Dashboard de Superhéroes</h1></a>
  </div>
</nav>

<div class="container mt-4">

  <!--Para mostrar mensajes de errores express-session-->
<% if (mensaje) { %>
  <div class="alert <%= mensaje.tipo === 'success' ? 'alert-success' : 'alert-danger' %>">
    <%= mensaje.texto %>
  </div>
<% } %>
